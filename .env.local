# Configurazione per sviluppo locale (Docker)

# Database
POSTGRES_URL=postgres://studio:studio123@localhost:5435/studio_cantini

# JWT
JWT_SECRET=mySuperSecretKey;)

# Server
PORT=9001
ENABLE_AUTO_MIGRATIONS=true

# MinIO (locale Docker)
MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9002
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_ARCHIVE_BUCKET=archive
USE_LOCAL_STORAGE=false

# Ollama locale
OLLAMA_URL=http://localhost:11434

# Qdrant locale
QDRANT_URL=http://localhost:6333

# Docling
DOCLING_URL=http://localhost:5001
USE_DOCLING_OCR=true
